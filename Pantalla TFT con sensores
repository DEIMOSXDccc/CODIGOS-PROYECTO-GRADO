  lv_obj_set_style_bg_color(screen, lv_color_hex(0x001B2E), 0);

  lv_obj_t * titulo = lv_label_create(screen);
  lv_label_set_text(titulo, "HIDROPONIA");
  lv_obj_set_style_text_color(titulo, lv_color_hex(0xFFFFFF), 0);
  lv_obj_set_style_text_font(titulo, &lv_font_montserrat_24, 0);
  lv_obj_align(titulo, LV_ALIGN_TOP_MID, 0, 6);

  // PANEL TEMPERATURAS
  lv_obj_t * panelTemp = lv_obj_create(screen);
  lv_obj_set_size(panelTemp, 150, 175);
  lv_obj_align(panelTemp, LV_ALIGN_BOTTOM_LEFT, 8, -8);
  lv_obj_set_style_bg_color(panelTemp, lv_color_hex(0x003049), 0);
  lv_obj_set_style_border_color(panelTemp, lv_color_hex(0x00E5FF), 0);
  lv_obj_set_style_border_width(panelTemp, 2, 0);
  lv_obj_set_style_radius(panelTemp, 12, 0);
  lv_obj_clear_flag(panelTemp, LV_OBJ_FLAG_SCROLLABLE);

  lv_obj_t * tituloTemp = lv_label_create(panelTemp);
  lv_label_set_text(tituloTemp, "TEMP");
  lv_obj_set_style_text_color(tituloTemp, lv_color_hex(0x00E5FF), 0);
  lv_obj_align(tituloTemp, LV_ALIGN_TOP_MID, 0, 6);

  labelT1 = crearTarjeta(panelTemp, "T1: --", 35);
  labelT2 = crearTarjeta(panelTemp, "T2: --", 80);
  labelT3 = crearTarjeta(panelTemp, "T3: --", 125);

  // PANEL DISTANCIA
  lv_obj_t * panelDist = lv_obj_create(screen);
  lv_obj_set_size(panelDist, 150, 175);
  lv_obj_align(panelDist, LV_ALIGN_BOTTOM_RIGHT, -8, -8);
  lv_obj_set_style_bg_color(panelDist, lv_color_hex(0x003049), 0);
  lv_obj_set_style_border_color(panelDist, lv_color_hex(0x00E5FF), 0);
  lv_obj_set_style_border_width(panelDist, 2, 0);
  lv_obj_set_style_radius(panelDist, 12, 0);
  lv_obj_clear_flag(panelDist, LV_OBJ_FLAG_SCROLLABLE);

  lv_obj_t * tituloDist = lv_label_create(panelDist);
  lv_label_set_text(tituloDist, "DIST");
  lv_obj_set_style_text_color(tituloDist, lv_color_hex(0x00E5FF), 0);
  lv_obj_align(tituloDist, LV_ALIGN_TOP_MID, 0, 6);

  labelDist = lv_label_create(panelDist);
  lv_label_set_text(labelDist, "-- cm");
  lv_obj_set_style_text_color(labelDist, lv_color_hex(0xFFFFFF), 0);
  lv_obj_set_style_text_font(labelDist, &lv_font_montserrat_24, 0);
  lv_obj_align(labelDist, LV_ALIGN_CENTER, 0, -25);

  labelAlerta = lv_label_create(panelDist);
  lv_label_set_text(labelAlerta, "NIVEL --");
  lv_obj_set_style_text_color(labelAlerta, lv_color_hex(0xFFFF00), 0);
  lv_obj_set_width(labelAlerta, 135);
  lv_obj_set_style_text_align(labelAlerta, LV_TEXT_ALIGN_CENTER, 0);
  lv_obj_align(labelAlerta, LV_ALIGN_CENTER, 0, 35);
}

//================ SETUP =================
void setup()
{
  Serial.begin(115200);

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED)
  {
    delay(500);
    Serial.println("Conectando a SENSORES_WIFI...");
  }

  Serial.println("WiFi conectado");

  tft.init();
  tft.setRotation(1);

  touchscreenSPI.begin(
    XPT2046_CLK,
    XPT2046_MISO,
    XPT2046_MOSI,
    XPT2046_CS
  );

  touch.begin(touchscreenSPI);
  touch.setRotation(2);

  lv_init();

  lv_disp_draw_buf_init(&draw_buf, buf, NULL, SCREEN_WIDTH * 10);

  static lv_disp_drv_t disp_drv;
  lv_disp_drv_init(&disp_drv);

  disp_drv.hor_res = SCREEN_WIDTH;
  disp_drv.ver_res = SCREEN_HEIGHT;
  disp_drv.flush_cb = my_disp_flush;
  disp_drv.draw_buf = &draw_buf;

  lv_disp_drv_register(&disp_drv);

  static lv_indev_drv_t indev_drv;
  lv_indev_drv_init(&indev_drv);

  indev_drv.type = LV_INDEV_TYPE_POINTER;
  indev_drv.read_cb = my_touch_read;

  lv_indev_drv_register(&indev_drv);

  crearInterfaz();
}

//================ LOOP =================
void loop()
{
  lv_timer_handler();

  static unsigned long t = 0;

  if (millis() - t >= 2000)
  {
    t = millis();
    actualizarDatos();
  }

  delay(5);
}
