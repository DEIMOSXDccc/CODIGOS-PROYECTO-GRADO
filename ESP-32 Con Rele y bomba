#include <WiFi.h>
#include <WebServer.h>

const char* ssid = "BOMBA_WIFI";
const char* password = "12345678";

WebServer server(80);

#define RELE 26

bool temporizadorActivo = false;
unsigned long inicioTiempo = 0;
unsigned long duracionTiempo = 0;

// LOW prende, HIGH apaga
void prenderRele()
{
  digitalWrite(RELE, LOW);
}

void apagarRele()
{
  digitalWrite(RELE, HIGH);
}

void encenderFijo()
{
  temporizadorActivo = false;
  prenderRele();
  server.send(200, "text/plain", "ON FIJO");
}

void encenderTemporizado()
{
  int segundos = 10;

  if (server.hasArg("seg"))
  {
    segundos = server.arg("seg").toInt();
  }

  if (segundos < 1) segundos = 1;
  if (segundos > 120) segundos = 120;

  prenderRele();

  temporizadorActivo = true;
  inicioTiempo = millis();
  duracionTiempo = segundos * 1000UL;

  server.send(200, "text/plain", "ON TIMER");
}

void apagarBomba()
{
  temporizadorActivo = false;
  apagarRele();
  server.send(200, "text/plain", "OFF");
}

void setup()
{
  Serial.begin(115200);

  digitalWrite(RELE, HIGH);
  pinMode(RELE, OUTPUT);
  apagarRele();

  WiFi.softAP(ssid, password);

  server.on("/1", encenderFijo);
  server.on("/timer", encenderTemporizado);
  server.on("/0", apagarBomba);

  server.begin();
}

void loop()
{
  server.handleClient();

  if (temporizadorActivo)
  {
    if (millis() - inicioTiempo >= duracionTiempo)
    {
      temporizadorActivo = false;
      apagarRele();
    }
  }
}
