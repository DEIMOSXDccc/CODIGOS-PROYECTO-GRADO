//================ TEXTO =================
void crearTitulo(const char * texto)
{
  lv_obj_t * titulo = lv_label_create(lv_scr_act());
  lv_label_set_text(titulo, texto);
  lv_obj_set_style_text_color(titulo, lv_color_hex(COLOR_TITULO), 0);
  lv_obj_set_style_text_font(titulo, &lv_font_montserrat_24, 0);
  lv_obj_align(titulo, LV_ALIGN_TOP_MID, 0, 8);
}

void crearTexto(const char * texto)
{
  lv_obj_t * panel = lv_obj_create(lv_scr_act());
  lv_obj_set_size(panel, 295, 145);
  lv_obj_align(panel, LV_ALIGN_CENTER, 0, 12);
  lv_obj_set_style_bg_color(panel, lv_color_hex(COLOR_PANEL), 0);
  lv_obj_set_style_border_color(panel, lv_color_hex(COLOR_TITULO), 0);
  lv_obj_set_style_border_width(panel, 2, 0);
  lv_obj_set_style_radius(panel, 12, 0);
  lv_obj_clear_flag(panel, LV_OBJ_FLAG_SCROLLABLE);

  lv_obj_t * label = lv_label_create(panel);
  lv_label_set_text(label, texto);
  lv_obj_set_width(label, 270);
  lv_obj_set_style_text_color(label, lv_color_hex(COLOR_TEXTO), 0);
  lv_obj_set_style_text_align(label, LV_TEXT_ALIGN_CENTER, 0);
  lv_obj_align(label, LV_ALIGN_CENTER, 0, 0);
}

//================ BOTONES =================
lv_obj_t * crearBoton(const char * texto, int x, int y, lv_event_cb_t cb)
{
  lv_obj_t * btn = lv_btn_create(lv_scr_act());
  lv_obj_set_size(btn, 135, 34);
  lv_obj_align(btn, LV_ALIGN_TOP_LEFT, x, y);
  lv_obj_set_style_bg_color(btn, lv_color_hex(COLOR_BOTON), 0);
  lv_obj_set_style_radius(btn, 9, 0);
  lv_obj_add_event_cb(btn, cb, LV_EVENT_CLICKED, NULL);

  lv_obj_t * label = lv_label_create(btn);
  lv_label_set_text(label, texto);
  lv_obj_set_style_text_color(label, lv_color_hex(0xFFFFFF), 0);
  lv_obj_center(label);

  return btn;
}

